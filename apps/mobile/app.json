{
  "expo": {
    "name": "Logistics Platform",
    "slug": "logistics-platform",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "logistics",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e40af"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.logistics.platform",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location for live shipment tracking and navigation.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We need your location for live shipment tracking during deliveries."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e40af"
      },
      "package": "com.logistics.platform",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Logistics Platform to use your location for tracking."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
