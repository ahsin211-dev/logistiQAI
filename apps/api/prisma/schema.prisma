generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SHIPPER
  DRIVER
  FLEET_MANAGER
  TRANSPORT_COMPANY
}

enum ShipmentStatus {
  CREATED
  ASSIGNED
  PICKUP_SCHEDULED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum ShipmentPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum VehicleStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  OUT_OF_SERVICE
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum AnomalyType {
  ROUTE_DEVIATION
  DUPLICATE_INVOICE
  UNEXPECTED_STOP
  PAYMENT_ANOMALY
  DRIVER_BEHAVIOR
  SUSPICIOUS_ACTIVITY
}

enum NotificationType {
  SHIPMENT_UPDATE
  PAYMENT
  ASSIGNMENT
  MAINTENANCE
  ANOMALY
  SYSTEM
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  phone         String?
  role          UserRole
  isVerified    Boolean   @default(false) @map("is_verified")
  isActive      Boolean   @default(true) @map("is_active")
  avatarUrl     String?   @map("avatar_url")
  companyId     String?   @map("company_id")
  company       Company?  @relation(fields: [companyId], references: [id])
  driver        Driver?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  shipmentsCreated Shipment[]       @relation("ShipperShipments")
  notifications    Notification[]
  supportChats     SupportChat[]
  auditLogs        AuditLog[]

  @@map("users")
}

model Company {
  id          String   @id @default(uuid())
  name        String
  taxId       String?  @map("tax_id")
  address     String?
  city        String?
  state       String?
  postalCode  String?  @map("postal_code")
  country     String?
  phone       String?
  email       String?
  isVerified  Boolean  @default(false) @map("is_verified")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users    User[]
  vehicles Vehicle[]
  drivers  Driver[]

  @@map("companies")
}

model Driver {
  id              String    @id @default(uuid())
  userId          String    @unique @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId       String?   @map("company_id")
  company         Company?  @relation(fields: [companyId], references: [id])
  licenseNumber   String    @map("license_number")
  licenseExpiry   DateTime? @map("license_expiry")
  rating          Float     @default(5.0)
  totalDeliveries Int       @default(0) @map("total_deliveries")
  isAvailable     Boolean   @default(true) @map("is_available")
  currentLat      Float?    @map("current_lat")
  currentLng      Float?    @map("current_lng")
  lastLocationAt  DateTime? @map("last_location_at")
  isVerified      Boolean   @default(false) @map("is_verified")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  assignments DriverAssignment[]
  fuelLogs    FuelLog[]

  @@map("drivers")
}

model Vehicle {
  id              String        @id @default(uuid())
  companyId       String        @map("company_id")
  company         Company       @relation(fields: [companyId], references: [id])
  plateNumber     String        @unique @map("plate_number")
  make            String
  model           String
  year            Int
  vehicleType     String        @map("vehicle_type")
  capacityWeight  Float         @map("capacity_weight")
  capacityVolume  Float         @map("capacity_volume")
  status          VehicleStatus @default(AVAILABLE)
  currentMileage  Float         @default(0) @map("current_mileage")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  maintenanceRecords VehicleMaintenance[]
  assignments        DriverAssignment[]
  fuelLogs           FuelLog[]

  @@map("vehicles")
}

model VehicleMaintenance {
  id              String    @id @default(uuid())
  vehicleId       String    @map("vehicle_id")
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id])
  maintenanceType String    @map("maintenance_type")
  description     String?
  scheduledAt     DateTime  @map("scheduled_at")
  completedAt     DateTime? @map("completed_at")
  cost            Float?
  mileageAt       Float?    @map("mileage_at")
  isPredicted     Boolean   @default(false) @map("is_predicted")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("vehicle_maintenance")
}

model FuelLog {
  id          String   @id @default(uuid())
  vehicleId   String   @map("vehicle_id")
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  driverId    String?  @map("driver_id")
  driver      Driver?  @relation(fields: [driverId], references: [id])
  liters      Float
  cost        Float
  mileageAt   Float    @map("mileage_at")
  stationName String?  @map("station_name")
  loggedAt    DateTime @default(now()) @map("logged_at")

  @@map("fuel_logs")
}

model Shipment {
  id                   String           @id @default(uuid())
  trackingNumber       String           @unique @map("tracking_number")
  shipperId            String           @map("shipper_id")
  shipper              User             @relation("ShipperShipments", fields: [shipperId], references: [id])
  status               ShipmentStatus   @default(CREATED)
  priority             ShipmentPriority @default(NORMAL)
  shipmentType         String           @map("shipment_type")
  weight               Float
  volume               Float?
  pickupStreet         String           @map("pickup_street")
  pickupCity           String           @map("pickup_city")
  pickupState          String           @map("pickup_state")
  pickupPostalCode     String           @map("pickup_postal_code")
  pickupCountry        String           @map("pickup_country")
  pickupLat            Float?           @map("pickup_lat")
  pickupLng            Float?           @map("pickup_lng")
  deliveryStreet       String           @map("delivery_street")
  deliveryCity         String           @map("delivery_city")
  deliveryState        String           @map("delivery_state")
  deliveryPostalCode   String           @map("delivery_postal_code")
  deliveryCountry      String           @map("delivery_country")
  deliveryLat          Float?           @map("delivery_lat")
  deliveryLng          Float?           @map("delivery_lng")
  scheduledPickupAt    DateTime?        @map("scheduled_pickup_at")
  scheduledDeliveryAt  DateTime?        @map("scheduled_delivery_at")
  actualPickupAt       DateTime?        @map("actual_pickup_at")
  actualDeliveryAt     DateTime?        @map("actual_delivery_at")
  estimatedDeliveryAt  DateTime?        @map("estimated_delivery_at")
  etaConfidence        Float?           @map("eta_confidence")
  notes                String?
  proofOfDeliveryUrl   String?          @map("proof_of_delivery_url")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  items          ShipmentItem[]
  documents      ShipmentDocument[]
  statusHistory  ShipmentStatusHistory[]
  locations      ShipmentLocation[]
  trackingEvents ShipmentTrackingEvent[]
  assignments    DriverAssignment[]
  payments       Payment[]
  invoices       Invoice[]
  routes         Route[]
  anomalyAlerts  AnomalyAlert[]

  @@map("shipments")
}

model ShipmentItem {
  id          String   @id @default(uuid())
  shipmentId  String   @map("shipment_id")
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  description String
  quantity    Int
  weight      Float
  volume      Float?
  isFragile   Boolean  @default(false) @map("is_fragile")
  sku         String?

  @@map("shipment_items")
}

model ShipmentDocument {
  id           String   @id @default(uuid())
  shipmentId   String   @map("shipment_id")
  shipment     Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  fileName     String   @map("file_name")
  fileUrl      String   @map("file_url")
  mimeType     String   @map("mime_type")
  documentType String   @map("document_type")
  ocrData      Json?    @map("ocr_data")
  isVerified   Boolean  @default(false) @map("is_verified")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  @@map("shipment_documents")
}

model ShipmentStatusHistory {
  id         String         @id @default(uuid())
  shipmentId String         @map("shipment_id")
  shipment   Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  status     ShipmentStatus
  notes      String?
  changedBy  String?        @map("changed_by")
  latitude   Float?
  longitude  Float?
  createdAt  DateTime       @default(now()) @map("created_at")

  @@map("shipment_status_history")
}

model ShipmentLocation {
  id         String   @id @default(uuid())
  shipmentId String   @map("shipment_id")
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  latitude   Float
  longitude  Float
  accuracy   Float?
  speed      Float?
  heading    Float?
  recordedAt DateTime @default(now()) @map("recorded_at")

  @@index([shipmentId, recordedAt])
  @@map("shipment_locations")
}

model ShipmentTrackingEvent {
  id          String   @id @default(uuid())
  shipmentId  String   @map("shipment_id")
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  eventType   String   @map("event_type")
  description String?
  latitude    Float?
  longitude   Float?
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("shipment_tracking_events")
}

model Route {
  id              String   @id @default(uuid())
  shipmentId      String   @map("shipment_id")
  shipment        Shipment @relation(fields: [shipmentId], references: [id])
  totalDistance   Float?   @map("total_distance")
  totalDuration   Int?     @map("total_duration")
  polyline        String?
  isOptimized     Boolean  @default(false) @map("is_optimized")
  optimizationLog Json?    @map("optimization_log")
  createdAt       DateTime @default(now()) @map("created_at")

  stops RouteStop[]

  @@map("routes")
}

model RouteStop {
  id        String  @id @default(uuid())
  routeId   String  @map("route_id")
  route     Route   @relation(fields: [routeId], references: [id], onDelete: Cascade)
  sequence  Int
  address   String
  latitude  Float
  longitude Float
  stopType  String  @map("stop_type")
  eta       DateTime?
  duration  Int?

  @@map("route_stops")
}

model DriverAssignment {
  id          String    @id @default(uuid())
  shipmentId  String    @map("shipment_id")
  shipment    Shipment  @relation(fields: [shipmentId], references: [id])
  driverId    String    @map("driver_id")
  driver      Driver    @relation(fields: [driverId], references: [id])
  vehicleId   String?   @map("vehicle_id")
  vehicle     Vehicle?  @relation(fields: [vehicleId], references: [id])
  assignedAt  DateTime  @default(now()) @map("assigned_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  isActive    Boolean   @default(true) @map("is_active")

  @@map("driver_assignments")
}

model Payment {
  id              String        @id @default(uuid())
  shipmentId      String        @map("shipment_id")
  shipment        Shipment      @relation(fields: [shipmentId], references: [id])
  amount          Float
  currency        String        @default("usd")
  status          PaymentStatus @default(PENDING)
  stripePaymentId String?       @map("stripe_payment_id")
  stripeSessionId String?       @map("stripe_session_id")
  metadata        Json?
  paidAt          DateTime?     @map("paid_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("payments")
}

model Invoice {
  id            String   @id @default(uuid())
  shipmentId    String   @map("shipment_id")
  shipment      Shipment @relation(fields: [shipmentId], references: [id])
  invoiceNumber String   @unique @map("invoice_number")
  amount        Float
  currency      String   @default("usd")
  pdfUrl        String?  @map("pdf_url")
  issuedAt      DateTime @default(now()) @map("issued_at")

  @@map("invoices")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  @@map("notifications")
}

model SupportChat {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  shipmentId String?  @map("shipment_id")
  role       String
  message    String
  isAi       Boolean  @default(false) @map("is_ai")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("support_chats")
}

model AiLog {
  id           String   @id @default(uuid())
  service      String
  prompt       String?
  response     String?
  inputTokens  Int?     @map("input_tokens")
  outputTokens Int?     @map("output_tokens")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("ai_logs")
}

model AnomalyAlert {
  id          String      @id @default(uuid())
  shipmentId  String?     @map("shipment_id")
  shipment    Shipment?   @relation(fields: [shipmentId], references: [id])
  type        AnomalyType
  severity    String      @default("medium")
  description String
  metadata    Json?
  isResolved  Boolean     @default(false) @map("is_resolved")
  createdAt   DateTime    @default(now()) @map("created_at")

  @@map("anomaly_alerts")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@map("audit_logs")
}
